rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Place enrichment — trip-scoped subcollection.
    // Reads only the current trip's docs (not all trips), so Firestore read cost
    // scales with trip size rather than total places across the system.
    // Write guard accepts either cached_at (core phase) or reviews_cached_at (reviews phase).
    match /place_enrichment/{tripId}/places/{placeId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && (request.resource.data.cached_at is number
                       || request.resource.data.reviews_cached_at is number);
    }
    match /trail_enrichment/{trailId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.cached_at is number;
    }

    // Trip-scoped — weather forecasts are date-specific to a trip window.
    match /weather_enrichment/{tripId}/{document=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.cached_at is number;
    }

    // Place entity cache — shared catalog backing EntityDetailSheet
    match /places/{placeId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Lock all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
